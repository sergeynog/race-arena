rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Community CSVs: listed in Firestore; guests need read to compare laps.
    match /csvs/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /avatars/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
